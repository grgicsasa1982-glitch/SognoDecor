<!DOCTYPE html>
<html lang="hr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sogno Decor</title>
  <style>
    body { font-family: Arial, sans-serif; margin:0; padding:0; background:#f8f8f8; color:#333; }
    header { background:#222; color:#fff; padding:20px 0; text-align:center; }
    nav a { color:#fff; margin:0 15px; text-decoration:none; font-weight:bold; }
    .hero { text-align:center; padding:60px 20px; background:#eee; }
    .hero h1 { font-size:2.5em; margin-bottom:10px; }
    .hero p { font-size:1.2em; }
    .section { max-width:1000px; margin:40px auto; padding:0 20px; }
    .portfolio { display:flex; flex-wrap:wrap; gap:20px; justify-content:center; }
    .portfolio-item { background:#fff; border:1px solid #ddd; width:300px; padding:10px; text-align:center; }
    .portfolio-item img { width:100%; height:auto; }
    footer { background:#222; color:#fff; text-align:center; padding:20px 0; margin-top:40px; }
    footer a { color:#fff; margin:0 10px; text-decoration:none; }
  </style>
</head>
<body>

  <header>
    <h1>Sogno Decor</h1>
    <nav>
      <a href="#home">Početna</a>
      <a href="#portfolio">Portfolio</a>
      <a href="#contact">Kontakt</a>
    </nav>
  </header>

  <section class="hero" id="home">
    <h1>Dobrodošli u Sogno Decor</h1>
    <p>Stilizirani i unikatni dekor za vaš dom i poslovni prostor</p>
  </section>

  <section class="section" id="portfolio">
    <h2 style="text-align:center;">Naši projekti</h2>
    <div class="portfolio">
      <div class="portfolio-item">
        <img src="https://via.placeholder.com/300x200?text=Proizvod+1" alt="Proizvod 1">
        <h3>Proizvod 1</h3>
        <p>Kratki opis proizvoda ili projekta.</p>
      </div>
      <div class="portfolio-item">
        <img src="https://via.placeholder.com/300x200?text=Proizvod+2" alt="Proizvod 2">
        <h3>Proizvod 2</h3>
        <p>Kratki opis proizvoda ili projekta.</p>
      </div>
      <div class="portfolio-item">
        <img src="https://via.placeholder.com/300x200?text=Proizvod+3" alt="Proizvod 3">
        <h3>Proizvod 3</h3>
        <p>Kratki opis proizvoda ili projekta.</p>
      </div>
    </div>
  </section>

  <section class="section" id="contact">
    <h2 style="text-align:center;">Kontakt</h2>
    <p style="text-align:center;">Email: <a href="mailto:info@sognodecor.hr">info@sognodecor.hr</a></p>
    <p style="text-align:center;">Telefon: +385 XX XXX XXXX</p>
    <p style="text-align:center;">Pratite nas na društvenim mrežama:
      <a href="#">Facebook</a> | <a href="#">Instagram</a> | <a href="#">Pinterest</a>
    </p>
  </section>

  <footer>
    &copy; 2026 Sogno Decor. Sva prava pridržana.
  </footer>

</body>
</html>
